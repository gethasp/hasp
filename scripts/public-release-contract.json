{
  "public_makefile_targets": {
    "verify-ci": {
      "deps_exact": ["check-links", "check-tidy", "check-generated-docs", "check-telemetry-release-gate", "workflow-lint", "shellcheck", "osv-scan", "test-scripts", "test", "lint"]
    },
    "release-gate": {
      "recipe_in_order": [
        "$(MAKE) verify-ci",
        "$(MAKE) check-telemetry-live-release-gate",
        "$(MAKE) evals",
        "$(MAKE) vulncheck",
        "$(MAKE) test-integration",
        "$(MAKE) test-race",
        "$(MAKE) coverage",
        "$(MAKE) conformance"
      ]
    }
  },
  "scripts": {
    "scripts/conformance.sh": {
      "commands_in_order": [
        "HASP_CHECK_PUBLIC_EXPORT_GATE_TARGET=verify-ci make verify-ci",
        "bash ./scripts/release-smoke.sh",
        "make evals",
        "make benchmark-smoke"
      ]
    }
  },
  "workflows": {
    "public_ci": {
      "path": ".github/workflows/ci.yml",
      "forbid_contains": ["paths:", "HASP_COVERAGE_TARGET: \"100\""],
      "jobs": {
        "fork-pr-verify": {
          "runs_on_contains": "ubuntu-latest",
          "run_contains": ["make osv-scan", "make check-links", "make check-generated-docs", "bash scripts/test-public-installer.sh", "bash scripts/test-package-public-release.sh", "make test", "make lint", "make coverage"]
        },
        "merge-gate": {
          "runs_on_contains": "ubuntu-latest",
          "run_contains": ["make osv-scan", "make check-links", "make check-generated-docs", "bash scripts/test-public-installer.sh", "bash scripts/test-package-public-release.sh", "make test", "make lint", "make coverage", "make conformance"]
        },
        "darwin-audit-coverage": {
          "runs_on_contains": "macos-15",
          "run_contains": ["make coverage-audit-platform"]
        }
      }
    },
    "public_release": {
      "path": ".github/workflows/release.yml",
      "jobs": {
        "release-smoke": {
          "run_contains": ["bash ./scripts/bootstrap_go_tools.sh release-smoke", "make test", "make test-race", "make coverage-audit-platform"]
        },
        "promote-latest-mirror": {
          "needs_include": ["publish-r2"],
          "run_contains": [
            "retry_latest_diff"
          ]
        },
        "publish-homebrew-tap": {
          "needs_include": ["promote-latest-mirror", "homebrew-formula-smoke"]
        },
        "published-release-live-smoke": {
          "needs_include": ["publish-homebrew-tap"],
          "run_contains": [
            "bash ./scripts/verify-live-release.sh --skip-github-release --brew-install \"${GITHUB_REF_NAME}\""
          ]
        },
        "build-public-release": {
          "runs_on_contains": "macos-15",
          "run_contains": [
            "bash ./scripts/bootstrap_go_tools.sh release-smoke",
            "bash ./scripts/package-public-release.sh \"${GITHUB_REF_NAME}\""
          ]
        },
        "github-release": {
          "needs_include": ["published-release-live-smoke"]
        }
      },
      "step_names_in_order": ["Promote latest release mirror", "Verify latest release mirror"]
    }
  }
}
